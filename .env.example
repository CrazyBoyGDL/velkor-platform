# ══════════════════════════════════════════════════════════
# Velkor Platform — Environment Variables Reference
# Copy relevant sections to each Railway service.
# NEVER commit actual values. All vars marked [REQUIRED]
# must be set before deployment.
# ══════════════════════════════════════════════════════════

# ── STRAPI (apps/api) ────────────────────────────────────
# [REQUIRED] PostgreSQL connection
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=velkor_platform
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=change-in-production

# [REQUIRED] Set to 'true' on Railway (PostgreSQL requires SSL)
DATABASE_SSL=false

# [REQUIRED] Generate with: openssl rand -base64 32
JWT_SECRET=change-in-production
ADMIN_JWT_SECRET=change-in-production
API_TOKEN_SALT=change-in-production
TRANSFER_TOKEN_SALT=change-in-production

# [REQUIRED] Comma-separated list of 32-char random strings
# Generate: node -e "console.log([...Array(4)].map(()=>require('crypto').randomBytes(16).toString('base64')).join(','))"
APP_KEYS=key1,key2,key3,key4

# [REQUIRED] Public URL of the Next.js frontend (for CORS whitelist)
FRONTEND_URL=http://localhost:3000

# Strapi server
HOST=0.0.0.0
PORT=1337
NODE_ENV=development

# ── NEXT.JS (apps/web) ───────────────────────────────────
# [REQUIRED] Private URL of Strapi — NOT exposed to the browser.
# Use Railway's internal network URL for same-project services.
STRAPI_URL=http://localhost:1337

# [OPTIONAL] WhatsApp Business number in international format (no + or spaces)
# If not set, the WhatsApp button is hidden instead of showing a broken link.
NEXT_PUBLIC_WHATSAPP_NUMBER=521XXXXXXXXXX

# [OPTIONAL] Plausible Analytics domain — privacy-first, no cookies.
# If not set, analytics are disabled entirely. Get your domain from plausible.io
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# [OPTIONAL] Calendly scheduling URL for the /contacto page.
# If not set, the "Agendar llamada" card shows "Disponible próximamente".
NEXT_PUBLIC_CALENDLY_URL=

NODE_ENV=development
