{
  "kind": "collectionType",
  "collectionName": "recursos",
  "info": {
    "singularName": "recurso",
    "pluralName": "recursos",
    "displayName": "Recurso",
    "description": "Recursos descargables / lead magnets"
  },
  "options": { "draftAndPublish": true },
  "attributes": {
    "title": { "type": "string", "required": true },
    "slug": { "type": "uid", "targetField": "title", "required": true },
    "description": { "type": "text", "required": true },
    "category": {
      "type": "enumeration",
      "enum": ["Identidad", "Redes", "CCTV", "Cloud", "Seguridad"],
      "required": true
    },
    "items": {
      "type": "json",
      "description": "Array de strings: qué incluye el recurso"
    },
    "hex": { "type": "string" },
    "fileUrl": {
      "type": "string",
      "description": "URL opcional al PDF (CDN o Storage)"
    },
    "technicalLevel": {
      "type": "enumeration",
      "enum": ["executive", "technical", "architecture", "governance"]
    },
    "technicalCategory": {
      "type": "enumeration",
      "enum": ["identity-governance", "network-infrastructure", "endpoint-management", "security-operations", "continuity-resilience", "cloud-modernization", "video-operations"]
    },
    "operationalTags": {
      "type": "json",
      "description": "Operational tags used for lead attribution and content reuse"
    },
    "maturityLevel": {
      "type": "enumeration",
      "enum": ["reactive", "controlled", "governed", "optimized"]
    },
    "engagementType": {
      "type": "enumeration",
      "enum": ["assessment", "implementation", "managed-services", "governance", "advisory"]
    },
    "relatedEvidence": {
      "type": "json"
    },
    "relatedCases": {
      "type": "json"
    },
    "architectureDiagram": {
      "type": "json"
    },
    "downloadableArtifact": {
      "type": "json",
      "description": "Structured artifact metadata: title, url, gated, format, evidenceId"
    },
    "governanceNotes": {
      "type": "text",
      "maxLength": 1500
    }
  }
}
