{
  "kind": "collectionType",
  "collectionName": "posts",
  "info": {
    "singularName": "post",
    "pluralName": "posts",
    "displayName": "Post",
    "description": "Blog articles"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true,
      "maxLength": 300
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "excerpt": {
      "type": "text",
      "maxLength": 400
    },
    "content": {
      "type": "richtext"
    },
    "category": {
      "type": "enumeration",
      "enum": ["Redes", "CCTV", "Cloud", "Intune", "Seguridad", "NOC"],
      "required": true
    },
    "readTime": {
      "type": "string",
      "maxLength": 20
    },
    "hex": {
      "type": "string",
      "maxLength": 20
    }
  }
}
